# =============================================================================
# ShopAgent Environment Variables
# Semana AI Data Engineer 2026
# Copy to .env and fill in your values: cp .env.example .env
# =============================================================================

# ShadowTraffic License (get free at shadowtraffic.io)
SHADOWTRAFFIC_LICENSE=your-license-key-here

# Postgres (Docker local — Days 1-3)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=shopagent
POSTGRES_USER=shopagent
POSTGRES_PASSWORD=shopagent

# Qdrant (Docker local — Days 1-3)
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=shopagent_reviews

# Anthropic (required for Claude — Days 1-4)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Supabase Cloud (Day 4 migration — optional until Day 4)
# SUPABASE_URL=https://xxxxx.supabase.co
# SUPABASE_KEY=your-anon-key-here

# Qdrant Cloud (Day 4 migration — optional until Day 4)
# QDRANT_CLOUD_URL=https://xxxxx.cloud.qdrant.io:6333
# QDRANT_CLOUD_API_KEY=your-qdrant-cloud-key

# LangFuse (Day 4 observability — optional until Day 4)
# LANGFUSE_SECRET_KEY=sk-lf-your-key
# LANGFUSE_PUBLIC_KEY=pk-lf-your-key
# LANGFUSE_BASE_URL=https://cloud.langfuse.com
